<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp5.NewPage1"
             Title="NewPage1">
    <VerticalStackLayout>
        <Label 
            Text="Mój dziennik"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />
        <Editor
            x:Name="EditorWpis"
            Placeholder="Wpisz tutaj co myślisz!"/>
        <HorizontalStackLayout
            HorizontalOptions="Center">
            <Button
            x:Name="DodajWpis"
            Text="Dodaj wpis"
            Clicked="OnZapiszTekstClicked"
            BackgroundColor="Green"/>
        <Button
            x:Name="UsunHistorie"
            Text="Usuń Historię przeglądania"
            Clicked="OnUsunTekstCilcked"
            Background="Red"/>
        </HorizontalStackLayout>
        <ScrollView>
            <Label
                x:Name="Hisotria"
                Text=""/>
        </ScrollView>
    </VerticalStackLayout>
</ContentPage>