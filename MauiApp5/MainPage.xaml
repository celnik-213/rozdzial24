<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp5.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Label Text="1. Zapis i odczyt tekstu"
                FontSize="18"
                FontAttributes="Bold" />
            
            <Label Text="Zapisz tekst do pliku, potem go odczytaj"
                   FontSize="12"
                   TextColor="Gray" />
            
            <Entry x:Name="ZapisEntry"
                Placeholder="Wpisz tekst do zapisania"
                FontSize="14" />

            <HorizontalStackLayout Spacing="10">
                <Button Text="Zapisz"
                        BackgroundColor="DarkBlue"
                        TextColor="White"
                        Clicked="OnZapiszTekstClicked" />
                
                <Button Text="Odczytaj"
                        BackgroundColor="DarkGreen"
                        TextColor="White"
                        Clicked="OnOdczytajTekstClicked" />
            </HorizontalStackLayout>
            <Frame BackgroundColor="#F5F5F5" Padding="12" CornerRadius="8">

                <Label x:Name="OdczytanyTekstLabel"
                       Text="(brak danych)"
                       FontSize="13"
                       TextColor="Gray" />
            </Frame>
            <BoxView HeightRequest="1" Color="LightGray" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
