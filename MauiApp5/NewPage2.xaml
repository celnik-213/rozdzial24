<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp5.NewPage2"
             Title="NewPage2">
    <VerticalStackLayout>
        <Label 
            Text="Eksport import plików"
            VerticalOptions="Center" 
            HorizontalOptions="Center" 
            FontSize="32"/>
        <Editor
            x:Name="EditorWpis"
            Placeholder="Wpisz coś tutaj!"/>
        <HorizontalStackLayout
            HorizontalOptions="Center">
            <Button
            x:Name="Eksportuj"
            Text="Ekspotruj"
            BackgroundColor="Green"
            Clicked="OnEksportClicked"/>
            <Button
            x:Name="Importuj"
            Text="Importuj"
            BackgroundColor="Red"
            Clicked="OnImportClicked"/>
            
        </HorizontalStackLayout>
        <Label
            Text=""
            x:Name="Informacja"/>
    </VerticalStackLayout>
</ContentPage>